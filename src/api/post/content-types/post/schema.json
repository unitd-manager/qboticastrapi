{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "acf": {
      "type": "json"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "excerpt": {
      "type": "richtext"
    },
    "content": {
      "type": "richtext"
    },
    "layout": {
      "type": "text"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "posts"
    },
    "wpPostIds": {
      "type": "string",
      "help": "Comma-separated WordPress post IDs to display data from (e.g., 40,81,101)"
    },
    "displayWpData": {
      "type": "boolean",
      "default": false,
      "help": "Enable to fetch and display WordPress post data"
    }
  }
}