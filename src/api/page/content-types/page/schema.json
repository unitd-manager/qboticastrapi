{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "displayName": "Page",
    "singularName": "page",
    "pluralName": "pages"
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "pageType": {
      "type": "enumeration",
      "enum": [
        "landing",
        "blog",
        "about",
        "service",
        "career",
        "resource"
      ],
      "default": "landing",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
