{
  "collectionName": "components_acf_sections_home_blog_post",
  "info": {
    "displayName": "Home Blog Post"
  },
  "attributes": {
    "main_title": {
      "type": "text"
    },
    "description": {
      "type": "text"
    },
    "post_type": {
      "type": "enumeration",
      "enum": [
        "recent_posts",
        "select_post"
      ]
    },
    "select_post": {
      "type": "json"
    },
    "recent_post_type": {
      "type": "enumeration",
      "enum": [
        "newsroom",
        "posts",
        "usecases",
        "case-studies"
      ]
    },
    "post_per_page": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 5
    }
  }
}
