{
  "collectionName": "components_acf_sections_classic_post_slider",
  "info": {
    "displayName": "Classic Post Slider"
  },
  "attributes": {
    "section_space_padding": {
      "type": "component",
      "repeatable": false,
      "component": "acf-sections.section-space-padding"
    },
    "main_title": {
      "type": "text"
    },
    "description": {
      "type": "richtext"
    },
    "source": {
      "type": "enumeration",
      "enum": [
        "posts",
        "related"
      ]
    },
    "posts_to_show": {
      "type": "enumeration",
      "enum": [
        "latest_published",
        "oldest_published",
        "latest_modified",
        "oldest_modified",
        "title_asc",
        "title_desc",
        "most_commented",
        "random",
        "custom"
      ]
    },
    "filter_by_category": {
      "type": "json"
    },
    "filter_by_tag": {
      "type": "json"
    },
    "filter_by_post_format": {
      "type": "enumeration",
      "enum": [
        "all",
        "standard"
      ]
    },
    "posts_limit": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 5
    },
    "show_title": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_description": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_feature_image": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_date": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "cta_button": {
      "type": "component",
      "component": "shared.menu-item",
      "repeatable": false
    },
    "class_name": {
      "type": "string"
    },
    "acf_id": {
      "type": "string"
    }
  }
}
