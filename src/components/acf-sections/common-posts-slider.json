{
  "collectionName": "components_acf_sections_common_posts_slider",
  "info": {
    "displayName": "Common Posts / Pages Slider"
  },
  "attributes": {
    "section_space_padding": {
      "type": "component",
      "repeatable": false,
      "component": "acf-sections.section-space-padding"
    },
    "main_title": {
      "type": "text"
    },
    "common_description": {
      "type": "richtext"
    },
    "post_type": {
      "type": "enumeration",
      "enum": [
        "post",
        "page"
      ]
    },
    "selected_items": {
      "type": "json",
      "customField": "plugin::custom.common-posts-picker"
    },
    "post_per_page": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 5
    },
    "order_by": {
      "type": "enumeration",
      "enum": [
        "date",
        "title",
        "default"
      ]
    },
    "show_title": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_feature_image": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_description": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "show_date": {
      "type": "enumeration",
      "enum": [
        "yes",
        "no"
      ]
    },
    "cta_button": {
      "type": "component",
      "component": "shared.menu-item",
      "repeatable": false
    },
    "class_name": {
      "type": "string"
    },
    "acf_id": {
      "type": "string"
    }
  }
}
